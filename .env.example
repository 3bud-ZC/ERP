# =============================================================================
# ERP System — Environment Configuration Template
# Copy this file to `.env` and fill in real values for your environment.
# Never commit `.env` to source control.
# =============================================================================

# ── Required ────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# PostgreSQL connection string
# Example: postgresql://user:password@host:5432/dbname?schema=public
DATABASE_URL=

# JWT signing secret (32+ characters, required for login/sessions)
JWT_SECRET=

# One-time bootstrap token for POST /api/init (required for production first deploy)
SETUP_TOKEN=

# NextAuth secret (legacy compatibility)
NEXTAUTH_SECRET=

# Public app URL (used for auth and redirect validation)
NEXTAUTH_URL=https://your-domain.com

# ── Optional / Production Helpers ───────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://your-domain.com/api
NEXT_TELEMETRY_DISABLED=1
ALLOW_SEED=false
E2E_BYPASS_RATE_LIMIT=0
E2E_ALLOW_AUTH_RESET=0
E2E_ALLOW_PRODUCTION_DB=0
SKIP_ENV_VALIDATION=1
BACKUP_DIR=./backups

# ── Docker / local PostgreSQL helpers ───────────────────────────────────────
# Use only for local development, CI, or Docker compose testing.
POSTGRES_DB=erp_system
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Email Configuration (optional)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASSWORD="your-app-password"
# SMTP_FROM="noreply@yourcompany.com"

# Optional external services
# STRIPE_PUBLIC_KEY="pk_test_..."
# STRIPE_SECRET_KEY="sk_test_..."
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION=""
# AWS_S3_BUCKET=""
