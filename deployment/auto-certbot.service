[Unit]
Description=Auto Certbot DNS Watcher and HTTPS Issuance for ERP
After=network-online.target nginx.service
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/local/bin/auto_certbot.sh
Restart=no
StandardOutput=append:/var/log/auto_certbot.log
StandardError=append:/var/log/auto_certbot.log
WorkingDirectory=/
User=root

[Install]
WantedBy=multi-user.target
