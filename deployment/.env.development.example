# Development environment variables
# Copy this file to .env for local development.

NODE_ENV=development
PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/erp_system
JWT_SECRET=dev-jwt-secret-32-characters-minimum
NEXTAUTH_SECRET=dev-nextauth-secret-32-characters-minimum
NEXTAUTH_URL=http://localhost:3000

ALLOW_SEED=true
E2E_BYPASS_RATE_LIMIT=1
E2E_ALLOW_AUTH_RESET=1
E2E_ALLOW_PRODUCTION_DB=0
SKIP_ENV_VALIDATION=1
BACKUP_DIR=./backups
