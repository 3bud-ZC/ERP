# Production environment variables for VPS deployments
# Copy this file to /var/www/erp/.env and replace placeholders.

NODE_ENV=production
PORT=3000
NEXT_PUBLIC_API_URL=https://your-domain.com/api

# PostgreSQL
DATABASE_URL=postgresql://postgres:strongpassword@localhost:5432/erp_system

# JWT signing secret (32+ chars, required — sub-32 chars triggers safe mode)
JWT_SECRET=

# Bootstrap token for POST /api/init (Authorization: Bearer <SETUP_TOKEN>)
SETUP_TOKEN=

# NextAuth secret (legacy compatibility)
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://your-domain.com

# Security / runtime
NEXT_TELEMETRY_DISABLED=1
ALLOW_SEED=false
E2E_BYPASS_RATE_LIMIT=0
E2E_ALLOW_AUTH_RESET=0
E2E_ALLOW_PRODUCTION_DB=0

# Optional backup directory
BACKUP_DIR=./backups
